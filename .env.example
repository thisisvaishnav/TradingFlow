# MongoDB connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=myapp

# JWT secret for auth tokens (use a strong random string)
JWT_SECRET=change-me-to-a-random-secret

# Executor polling interval in milliseconds
EXECUTOR_POLL_INTERVAL_MS=10000

# Resend email service
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="TradingFlow <noreply@yourdomain.com>"

# Backend CORS — comma-separated origins allowed to call the API
# Set this to your frontend domain in production
CORS_ORIGIN=https://tradingflow.vaishnav.email

# Client build — the API URL the frontend will call
# Used at BUILD TIME by Vite (prefix with VITE_)
VITE_API_BASE_URL=https://tradingflow.vaishnav.email/api

# Backend port (defaults to 3001)
PORT=3001
